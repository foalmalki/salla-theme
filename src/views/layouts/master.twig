<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ store.name|default('Afaq Store') }}</title>
  <style>
    body{margin:0;font-family:Tahoma,Arial,sans-serif;background:#f6f8fb;color:#111}
    .wrap{max-width:1100px;margin:0 auto;padding:20px}
    .bar{background:#fff;border-bottom:1px solid #e5e7eb}
    .hero{background:#fff;border:1px solid #e5e7eb;border-radius:12px;padding:28px;margin-top:20px}
  </style>
</head>
<body>
  <header class="bar"><div class="wrap"><strong>{{ store.name|default('Afaq') }}</strong></div></header>
  <main class="wrap">
    {% block content %}{% endblock %}
  </main>
</body>
</html>
