<!doctype html>
<html lang="{{ language.code|default('ar') }}" dir="{{ theme.is_rtl ? 'rtl' : 'ltr' }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{% block page_title %}{{ store.name|default('Afaq Store') }}{% endblock %}</title>
  <meta name="description" content="{% block meta_description %}{{ 'meta.default_description'|trans }}{% endblock %}">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="stylesheet" href="{{ 'styles/main.css'|asset }}">
  {% block head_extra %}{% endblock %}
</head>
<body class="theme-afaq {{ theme.is_rtl ? 'is-rtl' : 'is-ltr' }}">
  {% component 'header.header' %}

  <main id="main-content" class="site-main">
    {% block content %}{% endblock %}
  </main>

  {% component 'footer.footer' %}

  <script defer src="{{ 'scripts/main.js'|asset }}"></script>
  {% block scripts %}{% endblock %}
</body>
</html>
