<aside class="order-summary">
  <h3>{{ 'cart.summary'|trans }}</h3>
  <div><span>{{ 'cart.subtotal'|trans }}</span><strong>799 SAR</strong></div>
  <div><span>{{ 'cart.shipping'|trans }}</span><strong>25 SAR</strong></div>
  <div><span>{{ 'cart.tax'|trans }}</span><strong>36 SAR</strong></div>
  <div class="order-summary__total"><span>{{ 'cart.total'|trans }}</span><strong>860 SAR</strong></div>
  <a class="btn btn--primary btn--full" href="/checkout">{{ 'cart.checkout'|trans }}</a>
</aside>
