<section class="section">
  <div class="container">
    {% include 'components/common/section-header.twig' with { title: 'home.featured_categories'|trans, action_url: '/categories' } %}
    <div class="category-grid">
      {% for i in 1..6 %}
        {% include 'components/product/category-card.twig' with {
          category: {
            name: 'category.label'|trans ~ ' ' ~ i,
            count: 12 + i,
            image: 'https://picsum.photos/400/300?random=' ~ (10 + i)
          }
        } %}
      {% endfor %}
    </div>
  </div>
</section>
