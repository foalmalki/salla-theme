<article class="product-card">
  <a href="{{ product.url|default('/product/sample') }}" class="product-card__image-wrap">
    <img src="{{ product.image|default('https://picsum.photos/460/520?random=1') }}" alt="{{ product.name|default('Product') }}" loading="lazy">
    {% if product.badge %}<span class="product-badge">{{ product.badge }}</span>{% endif %}
  </a>
  <div class="product-card__body">
    <h3><a href="{{ product.url|default('/product/sample') }}">{{ product.name|default('Premium Product') }}</a></h3>
    <p class="product-price">
      <strong>{{ product.price|default('199 SAR') }}</strong>
      {% if product.old_price %}<del>{{ product.old_price }}</del>{% endif %}
    </p>
    <button class="btn btn--primary btn--full">{{ 'product.add_to_cart'|trans }}</button>
  </div>
</article>
