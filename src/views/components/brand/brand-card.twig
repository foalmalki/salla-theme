<article class="brand-card">
  <a href="{{ brand.url|default('/brands/sample') }}">
    <img src="{{ brand.image|default('https://picsum.photos/360/220?random=1') }}" alt="{{ brand.name|default('Brand') }}" loading="lazy">
    <h3>{{ brand.name|default('Brand Name') }}</h3>
    <p>{{ brand.description|default('Premium quality and trusted products.') }}</p>
  </a>
</article>
