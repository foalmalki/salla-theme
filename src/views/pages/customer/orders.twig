{% extends 'layouts/master.twig' %}

{% block page_title %}{{ 'customer.orders'|trans }}{% endblock %}

{% block content %}
<section class="section">
  <div class="container customer-layout">
    {% include 'components/customer/sidebar.twig' %}
    <div class="customer-content">
      <h1>{{ 'customer.orders'|trans }}</h1>
      <table class="table">
        <thead><tr><th>#</th><th>{{ 'customer.date'|trans }}</th><th>{{ 'customer.status'|trans }}</th><th>{{ 'cart.total'|trans }}</th></tr></thead>
        <tbody>
        {% for i in 1..5 %}
          <tr><td>#10{{ i }}</td><td>2026-04-0{{ i }}</td><td>{{ 'customer.completed'|trans }}</td><td>{{ 180 + i * 32 }} SAR</td></tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>
{% endblock %}
