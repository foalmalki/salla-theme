{% extends 'layouts/master.twig' %}

{% block page_title %}{{ 'cart.title'|trans }}{% endblock %}

{% block content %}
<section class="section">
  <div class="container cart-layout">
    <div class="cart-list">
      <h1>{{ 'cart.title'|trans }}</h1>
      {% for i in 1..3 %}
        {% include 'components/cart/cart-item.twig' with {
          item: {
            name: 'cart.item'|trans ~ ' ' ~ i,
            variant: 'M / Black',
            qty: i,
            price: (99 + i * 50) ~ ' SAR',
            image: 'https://picsum.photos/120/120?random=' ~ (120 + i)
          }
        } %}
      {% endfor %}
      {% include 'components/cart/cart-upsell.twig' %}
    </div>
    {% include 'components/cart/order-summary.twig' %}
  </div>
</section>
{% endblock %}

{% block scripts %}
  <script defer src="{{ 'scripts/cart.js'|asset }}"></script>
{% endblock %}
